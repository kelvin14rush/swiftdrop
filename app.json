{
  "expo": {
    "name": "SwiftDrop",
    "slug": "swiftdrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swiftdrop",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kelvin14rush.swiftdrop",
      "supportsTablet": true
    },
    "android": {
      "package": "com.kelvin14rush.swiftdrop",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B00",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF6B00",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SwiftDrop uses your photos to upload your ID for rider verification.",
          "cameraPermission": "SwiftDrop uses your camera for the rider verification selfie."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bfc8b37d-2fd3-467a-98bb-8e9f777fdbb2"
      }
    },
    "owner": "kelvin_69"
  }
}
